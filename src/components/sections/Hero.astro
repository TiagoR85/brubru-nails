---
import { siteConfig } from '../../lib/utils';
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden bg-brand-bg">
  <!-- Decorative dots -->
  <div class="hero-decoration absolute top-20 left-10 w-3 h-3 rounded-full bg-brand-rose/40 animate-fade-in" style="animation-delay: 0.2s;"></div>
  <div class="hero-decoration absolute top-40 right-20 w-4 h-4 rounded-full bg-brand-champagne/30 animate-fade-in" style="animation-delay: 0.4s;"></div>
  <div class="hero-decoration absolute bottom-32 left-1/4 w-2 h-2 rounded-full bg-brand-rose/30 animate-fade-in" style="animation-delay: 0.6s;"></div>
  <div class="hero-decoration absolute top-1/3 right-1/3 w-3 h-3 rounded-full bg-brand-champagne/20 animate-fade-in" style="animation-delay: 0.8s;"></div>
  <div class="hero-decoration absolute bottom-20 right-10 w-5 h-5 rounded-full bg-brand-rose/20 animate-fade-in" style="animation-delay: 1s;"></div>
  <div class="hero-decoration absolute top-1/4 left-1/3 w-2 h-2 rounded-full bg-brand-gray-light/60 animate-fade-in" style="animation-delay: 1.2s;"></div>

  <div class="container-premium w-full pt-24 pb-12 lg:pt-0 lg:pb-0">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Content -->
      <div class="hero-content order-2 lg:order-1">
        <div class="animate-slide-up" style="animation-delay: 0.1s;">
          <span class="badge mb-6 inline-flex">
            Mais de 20 anos de experiência
          </span>
        </div>

        <h1 class="heading-xl text-brand-graphite mt-6 mb-6 animate-slide-up" style="animation-delay: 0.2s;">
          Transforme seu talento em um{' '}
          <span class="text-gradient">negócio de sucesso</span>
        </h1>

        <p class="text-body text-brand-graphite/70 max-w-xl mb-10 animate-slide-up" style="animation-delay: 0.3s;">
          {siteConfig.description}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 animate-slide-up" style="animation-delay: 0.4s;">
          <a href="/produtos" class="btn-primary">
            Conhecer Produtos
          </a>
          <a href="/sobre" class="btn-secondary">
            Minha História
          </a>
        </div>
      </div>

      <!-- Right: Image / Gradient placeholder -->
      <div class="hero-image order-1 lg:order-2 animate-scale-in" style="animation-delay: 0.3s;">
        <div class="relative w-full aspect-[4/5] lg:aspect-square rounded-3xl overflow-hidden shadow-premium">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-rose via-brand-champagne to-brand-rose/60"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-brand-graphite/20 to-transparent"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center text-white/90 px-8">
              <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <span class="font-heading font-bold text-3xl">BN</span>
              </div>
              <p class="font-heading font-medium text-lg">Bruna — Brubru Nails</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
