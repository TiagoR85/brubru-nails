---
import { timelineItems } from '../../lib/utils';
---

<section id="jornada" class="section-padding bg-white">
  <div class="container-premium">
    <div class="text-center mb-16 lg:mb-20">
      <span class="badge mb-4 inline-block">Jornada</span>
      <h2 class="heading-lg text-brand-graphite mb-4">Minha Jornada</h2>
      <p class="text-body text-muted max-w-2xl mx-auto">
        De apaixonada por unhas a referência nacional
      </p>
    </div>

    <div class="relative max-w-4xl mx-auto">
      {/* Timeline vertical line */}
      <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-px bg-gradient-to-b from-brand-rose/20 via-brand-champagne/40 to-brand-rose/20"></div>

      <div class="space-y-12 md:space-y-16">
        {timelineItems.map((item, index) => {
          const isEven = index % 2 === 0;
          return (
            <div
              class:list={[
                'timeline-item relative flex items-start gap-6 md:gap-0',
                isEven ? 'md:flex-row' : 'md:flex-row-reverse',
              ]}
            >
              {/* Dot indicator */}
              <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-brand-rose border-4 border-white shadow-medium z-10 mt-1.5"></div>

              {/* Content card */}
              <div class:list={[
                'ml-12 md:ml-0 md:w-[calc(50%-2.5rem)]',
                isEven ? 'md:pr-8 md:text-right' : 'md:pl-8 md:text-left',
              ]}>
                <div class="card-premium">
                  <span class="inline-block px-3 py-1 mb-3 text-xs font-heading font-semibold tracking-wide uppercase bg-brand-champagne/10 text-brand-champagne rounded-full">
                    {item.year}
                  </span>
                  <h3 class="heading-sm text-brand-graphite mb-2">{item.title}</h3>
                  <p class="text-body text-muted">{item.description}</p>
                </div>
              </div>

              {/* Empty spacer for opposite side on desktop */}
              <div class="hidden md:block md:w-[calc(50%-2.5rem)]"></div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
