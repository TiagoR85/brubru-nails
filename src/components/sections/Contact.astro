---
import { siteConfig } from '../../lib/utils';

const contactInfo = [
  {
    label: 'WhatsApp',
    value: siteConfig.social.whatsapp,
    display: siteConfig.social.phone,
    href: siteConfig.social.whatsapp,
    icon: 'whatsapp',
  },
  {
    label: 'Email',
    value: siteConfig.social.email,
    display: siteConfig.social.email,
    href: `mailto:${siteConfig.social.email}`,
    icon: 'email',
  },
  {
    label: 'Instagram',
    value: '@brubrunails',
    display: '@brubrunails',
    href: siteConfig.social.instagram,
    icon: 'instagram',
  },
];
---

<section class="contact-section section-padding">
  <div class="container-premium">
    <div class="text-center mb-12 lg:mb-16">
      <h2 class="heading-lg text-brand-graphite mb-4">
        Fale <span class="text-gradient">Conosco</span>
      </h2>
      <p class="text-body text-muted max-w-2xl mx-auto">
        Estamos aqui para ajudar
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left: Contact Form -->
      <div class="contact-form-wrapper">
        <form id="contact-form" class="card-premium space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-brand-graphite mb-2">Nome</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Seu nome completo"
              class="input-field"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-brand-graphite mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="seu@email.com"
              class="input-field"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-brand-graphite mb-2">Mensagem</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              placeholder="Como podemos ajudar?"
              class="input-field resize-none"
            ></textarea>
          </div>

          <button type="submit" class="btn-primary w-full">
            Enviar Mensagem
            <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </button>

          <!-- Success Message (hidden by default) -->
          <div id="form-success" class="hidden text-center py-6">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-brand-rose/10 flex items-center justify-center">
              <svg class="w-8 h-8 text-brand-rose" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="heading-sm text-brand-graphite mb-2">Mensagem Enviada!</h3>
            <p class="text-body text-muted">Obrigada pelo contato. Retornaremos em breve.</p>
          </div>
        </form>
      </div>

      <!-- Right: Contact Info Cards -->
      <div class="space-y-6">
        {contactInfo.map((info) => (
          <a href={info.href} target={info.icon !== 'email' ? '_blank' : undefined} rel="noopener noreferrer" class="card-premium flex items-center gap-5 group">
            <div class="w-14 h-14 rounded-2xl bg-brand-rose/10 flex items-center justify-center shrink-0 group-hover:bg-brand-champagne/20 transition-colors duration-300">
              {info.icon === 'whatsapp' && (
                <svg class="w-7 h-7 text-brand-rose group-hover:text-brand-champagne transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
                </svg>
              )}
              {info.icon === 'email' && (
                <svg class="w-7 h-7 text-brand-rose group-hover:text-brand-champagne transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              )}
              {info.icon === 'instagram' && (
                <svg class="w-7 h-7 text-brand-rose group-hover:text-brand-champagne transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <rect x="2" y="2" width="20" height="20" rx="5" stroke-width="2" />
                  <circle cx="12" cy="12" r="5" stroke-width="2" />
                  <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="font-heading font-semibold text-brand-graphite mb-1">{info.label}</h3>
              <p class="text-body text-muted">{info.display}</p>
            </div>
            <svg class="w-5 h-5 text-brand-graphite/30 ml-auto shrink-0 group-hover:text-brand-champagne transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    successMessage?.classList.remove('hidden');
  });
</script>

<style>
  .contact-section {
    background: linear-gradient(180deg, var(--white) 0%, var(--bg-primary) 50%, var(--white) 100%);
  }

  .contact-form-wrapper {
    opacity: 0;
    transform: translateY(20px);
  }

  .contact-form-wrapper.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .space-y-6 > * {
    opacity: 0;
    transform: translateY(20px);
  }

  .space-y-6 > *.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .space-y-6 > *:nth-child(1) { transition-delay: 100ms; }
  .space-y-6 > *:nth-child(2) { transition-delay: 200ms; }
  .space-y-6 > *:nth-child(3) { transition-delay: 300ms; }
</style>
