---
import BaseLayout from '../layouts/BaseLayout.astro';
import { products } from '../lib/utils';
---

<BaseLayout title="Produtos">
  <section class="hero-section section-padding">
    <div class="container-premium">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="heading-xl text-brand-graphite mb-6">
          Nossas <span class="text-gradient">Ferramentas</span>
        </h1>
        <p class="text-body text-muted text-lg sm:text-xl max-w-2xl mx-auto">
          Soluções digitais criadas por quem entende o mercado das unhas.
          Ferramentas práticas para transformar seu talento em um negócio de sucesso.
        </p>
      </div>
    </div>
  </section>

  <section class="products-section section-padding">
    <div class="container-premium">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 sm:gap-10">
        {products.map((product) => (
          <div class="product-card card-premium flex flex-col h-full group">
            <div class="relative overflow-hidden rounded-2xl mb-6">
              <div class="aspect-[16/10] bg-gradient-to-br from-brand-rose/20 via-brand-champagne/20 to-brand-rose/10 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
                <svg class="w-20 h-20 text-brand-rose/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
              </div>
              {product.badge && (
                <span class="absolute top-3 right-3 badge">{product.badge}</span>
              )}
            </div>

            <div class="flex flex-col flex-1">
              <h2 class="heading-sm text-brand-graphite mb-3">{product.name}</h2>
              <p class="text-body text-muted mb-5">{product.description}</p>

              {product.features && product.features.length > 0 && (
                <ul class="space-y-2.5 mb-6 flex-1">
                  {product.features.map((feature) => (
                    <li class="flex items-start gap-2.5 text-sm text-brand-graphite/70">
                      <svg class="w-5 h-5 text-brand-champagne shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              )}

              <a
                href={`/produtos/${product.id}`}
                class="btn-primary w-full text-center mt-auto"
              >
                Ver Detalhes
                <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-section section-padding">
    <div class="container-premium">
      <div class="cta-card rounded-3xl p-8 sm:p-12 text-center">
        <h2 class="heading-md text-white mb-4">Pronta para transformar seu negócio?</h2>
        <p class="text-body text-white/80 max-w-xl mx-auto mb-8">
          Escolha a ferramenta ideal para o momento da sua carreira e comece hoje mesmo.
        </p>
        <a href="https://wa.me/5511999999999" target="_blank" rel="noopener noreferrer" class="btn-primary bg-white text-brand-champagne hover:bg-white/90">
          Fale Conosco
          <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--white) 100%);
  }

  .products-section {
    background: var(--white);
  }

  .product-card {
    opacity: 0;
    transform: translateY(20px);
  }

  .product-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .product-card:nth-child(1) { transition-delay: 0ms; }
  .product-card:nth-child(2) { transition-delay: 100ms; }
  .product-card:nth-child(3) { transition-delay: 200ms; }
  .product-card:nth-child(4) { transition-delay: 300ms; }

  .product-card:hover {
    transform: translateY(-4px);
  }

  .cta-section {
    background: var(--white);
  }

  .cta-card {
    background: linear-gradient(135deg, var(--rose) 0%, var(--champagne) 100%);
  }
</style>
