---
import BaseLayout from '../layouts/BaseLayout.astro';
import Contact from '../components/sections/Contact.astro';
import { siteConfig } from '../lib/utils';
---

<BaseLayout title="Contato">
  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-24 bg-brand-bg overflow-hidden">
    <!-- Decorative dots -->
    <div class="absolute top-20 left-10 w-3 h-3 rounded-full bg-brand-rose/40 animate-fade-in" style="animation-delay: 0.2s;"></div>
    <div class="absolute top-32 right-20 w-4 h-4 rounded-full bg-brand-champagne/30 animate-fade-in" style="animation-delay: 0.4s;"></div>
    <div class="absolute bottom-10 left-1/4 w-2 h-2 rounded-full bg-brand-rose/30 animate-fade-in" style="animation-delay: 0.6s;"></div>

    <div class="container-premium text-center">
      <span class="badge mb-6 inline-flex animate-slide-up" style="animation-delay: 0.1s;">
        Estamos aqui para você
      </span>

      <h1 class="heading-xl text-brand-graphite mt-6 mb-6 animate-slide-up" style="animation-delay: 0.2s;">
        Fale <span class="text-gradient">Conosco</span>
      </h1>

      <p class="text-body text-brand-graphite/70 max-w-2xl mx-auto animate-slide-up" style="animation-delay: 0.3s;">
        Tire suas dúvidas, solicite informações ou tire um orçamento. 
        Nossa equipe está pronta para ajudar você a alcançar o sucesso no mercado das unhas.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <Contact />

  <!-- Map & Additional Info -->
  <section class="section-padding bg-white">
    <div class="container-premium">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Map Placeholder -->
        <div class="card-premium overflow-hidden p-0">
          <div class="relative w-full aspect-video lg:aspect-[4/3] bg-gradient-to-br from-brand-gray-light to-brand-bg flex items-center justify-center">
            <div class="text-center px-8">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-brand-rose/10 flex items-center justify-center">
                <svg class="w-8 h-8 text-brand-rose" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <h3 class="heading-sm text-brand-graphite mb-2">{siteConfig.address.city}, {siteConfig.address.state}</h3>
              <p class="text-body text-muted">Brasil</p>
              <p class="text-sm text-brand-graphite/50 mt-2">Atendimento 100% online</p>
            </div>
          </div>
        </div>

        <!-- Additional Contact Info -->
        <div class="space-y-6">
          <div class="card-premium">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-2xl bg-brand-champagne/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-brand-champagne" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-brand-graphite mb-1">CNPJ</h3>
                <p class="text-body text-muted">{siteConfig.cnpj}</p>
              </div>
            </div>
          </div>

          <div class="card-premium">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-2xl bg-brand-rose/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-brand-rose" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-brand-graphite mb-1">Email</h3>
                <p class="text-body text-muted">{siteConfig.social.email}</p>
              </div>
            </div>
          </div>

          <div class="card-premium">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-2xl bg-brand-champagne/10 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-brand-champagne" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-brand-graphite mb-1">Telefone</h3>
                <p class="text-body text-muted">{siteConfig.social.phone}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
